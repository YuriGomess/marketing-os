// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  email     String?
  telefone  String?
  empresa   String?
  status    String   @default("ativo")
  createdAt DateTime @default(now())

  integrations   Integration[]
  conversations  AIConversation[]
  integrationAccounts IntegrationAccount[]
}

enum IntegrationProvider {
  META_ADS
  GOOGLE_ADS
  TIKTOK_ADS
  GOOGLE_ANALYTICS
  KOMMO
  WHATSAPP
  SHOPIFY
  YAMPI
  INTERNAL
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  EXPIRED
}

enum AIMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum AIActionStatus {
  SUCCESS
  ERROR
  PENDING
  CONFIRMED
  REJECTED
}

enum AgentType {
  ADS
}

enum AgentExecutionMode {
  READ_ONLY
  SUGGEST_ONLY
  CONFIRM_BEFORE_ACTION
}

enum AutomationProvider {
  META_ADS
  WHATSAPP
  GOOGLE_ADS
  TIKTOK_ADS
  FINANCE
  CRM
  TASKS
  NOTIFICATIONS
  INTERNAL
}

enum AutomationTriggerType {
  CRON
  MANUAL
  EVENT
}

enum AutomationExecutionMode {
  SIMULATE
  LIVE
}

enum AutomationOperator {
  GREATER_THAN
  GREATER_THAN_OR_EQUAL
  LESS_THAN
  LESS_THAN_OR_EQUAL
  EQUAL
  NOT_EQUAL
  CONTAINS
  NOT_CONTAINS
}

enum AutomationActionType {
  NOTIFY
  ADJUST_BUDGET
  CREATE_TASK
  CREATE_ALERT
  CALL_WEBHOOK
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  SKIPPED
}

enum AutomationScopeEntityType {
  CLIENT
  INTEGRATION
  ACCOUNT
  CAMPAIGN
  ADSET
  AD
  CONTACT
  DEAL
  TASK
  CHANNEL
  CUSTOM
}

enum WhatsappProvider {
  EVOLUTION
  META_CLOUD
  OFFICIAL
  INTERNAL
}

enum WhatsappInstanceStatus {
  DISCONNECTED
  CONNECTING
  QRCODE
  CONNECTED
  ERROR
}

enum WhatsappConversationStatus {
  OPEN
  ARCHIVED
  CLOSED
}

enum WhatsappMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsappMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  UNKNOWN
}

model Integration {
  id          String              @id @default(cuid())
  clientId    String?
  provider    IntegrationProvider
  accountName String
  accountId   String
  status      IntegrationStatus
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  client      Cliente?                @relation(fields: [clientId], references: [id])
  credential  IntegrationCredential?
  accounts    IntegrationAccount[]

  @@index([clientId])
  @@index([provider])
  @@index([status])
}

model IntegrationAccount {
  id                  String              @id @default(cuid())
  integrationId       String
  clientId            String?
  provider            IntegrationProvider @default(META_ADS)
  externalAccountId   String
  externalAccountName String
  currency            String?
  timezoneName        String?
  status              String?
  isActive            Boolean             @default(true)
  isDefault           Boolean             @default(false)
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  integration         Integration         @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  client              Cliente?            @relation(fields: [clientId], references: [id])

  @@unique([integrationId, externalAccountId])
  @@index([clientId])
  @@index([provider])
  @@index([isActive])
  @@index([isDefault])
  @@index([externalAccountName])
}

model IntegrationCredential {
  id            String      @id @default(cuid())
  integrationId String      @unique
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  tokenType     String?
  scope         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model AIConversation {
  id        String      @id @default(cuid())
  title     String?
  clientId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  client    Cliente?    @relation(fields: [clientId], references: [id])
  messages  AIMessage[]
  actionLogs AIActionLog[]

  @@index([clientId])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           AIMessageRole
  content        String
  toolName       String?
  toolCallId     String?
  createdAt      DateTime       @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
}

model AIActionLog {
  id             String              @id @default(cuid())
  conversationId String?
  provider       IntegrationProvider?
  action         String
  status         AIActionStatus
  input          Json?
  output         Json?
  errorMessage   String?
  createdAt      DateTime            @default(now())

  conversation   AIConversation?     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([provider])
  @@index([status])
}

model Agent {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  type       AgentType
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  config     AgentConfig?
  tools      AgentTool[]
  thresholds AgentThreshold[]

  @@index([type])
  @@index([isActive])
}

model AgentConfig {
  id               String             @id @default(cuid())
  agentId          String             @unique
  systemPrompt     String
  strategicContext String?
  executionMode    AgentExecutionMode @default(READ_ONLY)
  modelName        String?
  temperature      Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  agent            Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentTool {
  id        String   @id @default(cuid())
  agentId   String
  toolName  String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolName])
  @@index([toolName])
}

model AgentThreshold {
  id        String   @id @default(cuid())
  agentId   String
  key       String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
  @@index([key])
}

model Automation {
  id             String                    @id @default(cuid())
  name           String
  description    String?
  provider       AutomationProvider
  triggerType    AutomationTriggerType     @default(CRON)
  cronExpression String
  executionMode  AutomationExecutionMode   @default(SIMULATE)
  isActive       Boolean                   @default(true)
  isDraft        Boolean                   @default(false)
  draftPayload   Json?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  scopes         AutomationScope[]
  rules          AutomationRule[]
  actions        AutomationAction[]
  runs           AutomationRun[]

  @@index([provider])
  @@index([isActive])
  @@index([nextRunAt])
  @@index([triggerType])
}

model AutomationScope {
  id           String                    @id @default(cuid())
  automationId String
  entityType   AutomationScopeEntityType
  entityId     String
  metadata     Json?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  automation   Automation                @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([entityType])
}

model AutomationRule {
  id           String             @id @default(cuid())
  automationId String
  metricKey    String
  operator     AutomationOperator
  value        Float
  metadata     Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  automation   Automation         @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([metricKey])
}

model AutomationAction {
  id           String               @id @default(cuid())
  automationId String
  actionType   AutomationActionType
  payload      Json?
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  automation   Automation           @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([actionType])
  @@index([sortOrder])
}

model AutomationRun {
  id           String              @id @default(cuid())
  automationId String
  status       AutomationRunStatus @default(PENDING)
  input        Json?
  output       Json?
  errorMessage String?
  startedAt    DateTime            @default(now())
  finishedAt   DateTime?
  createdAt    DateTime            @default(now())

  automation   Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([status])
  @@index([startedAt])
}

model WhatsappInstance {
  id                 String                 @id @default(cuid())
  name               String
  provider           WhatsappProvider
  externalInstanceId String?
  status             WhatsappInstanceStatus @default(DISCONNECTED)
  phoneNumber        String?
  qrCode             String?
  webhookUrl         String?
  metadata           Json?
  connectedAt        DateTime?
  disconnectedAt     DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  contacts           WhatsappContact[]
  conversations      WhatsappConversation[]
  messages           WhatsappMessage[]
  eventLogs          WhatsappEventLog[]

  @@index([provider])
  @@index([status])
  @@index([externalInstanceId])
}

model WhatsappContact {
  id                String           @id @default(cuid())
  instanceId        String
  externalContactId String
  name              String?
  phone             String
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  instance          WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  conversations     WhatsappConversation[]
  messages          WhatsappMessage[]

  @@unique([instanceId, externalContactId])
  @@index([instanceId])
  @@index([phone])
}

model WhatsappConversation {
  id                     String                     @id @default(cuid())
  instanceId             String
  contactId              String
  externalConversationId String?
  lastMessageAt          DateTime?
  unreadCount            Int                        @default(0)
  status                 WhatsappConversationStatus @default(OPEN)
  metadata               Json?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  instance               WhatsappInstance           @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  contact                WhatsappContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages               WhatsappMessage[]

  @@unique([instanceId, contactId])
  @@index([instanceId])
  @@index([contactId])
  @@index([lastMessageAt])
  @@index([status])
}

model WhatsappMessage {
  id                String                   @id @default(cuid())
  instanceId        String
  conversationId    String
  contactId         String?
  externalMessageId String?
  direction         WhatsappMessageDirection
  messageType       WhatsappMessageType      @default(TEXT)
  textContent       String?
  mediaUrl          String?
  rawPayload        Json?
  sentAt            DateTime?
  receivedAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  instance          WhatsappInstance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  conversation      WhatsappConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact           WhatsappContact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([instanceId])
  @@index([conversationId])
  @@index([contactId])
  @@index([externalMessageId])
  @@index([direction])
  @@index([createdAt])
}

model WhatsappEventLog {
  id          String           @id @default(cuid())
  instanceId  String?
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime         @default(now())

  instance    WhatsappInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)

  @@index([instanceId])
  @@index([eventType])
  @@index([createdAt])
}
